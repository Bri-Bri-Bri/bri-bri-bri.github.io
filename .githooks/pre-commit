#!/bin/sh
# Bump the cache-version timestamp in every service worker on each commit,
# so browsers discard stale cached assets after a deploy.
#
# Convention: every sw.js in this repo uses
#   const CACHE_VERSION = 'project-name-vYYYYMMDDHHmmss';
# The project prefix (e.g. 'hands-free-', 'pomodoro-') stays constant;
# only the vYYYYMMDDHHmmss timestamp is replaced.  The prefix scopes each
# SW's cache-purge to its own project, since Cache Storage is origin-wide.

VERSION="v$(date -u +%Y%m%d%H%M%S)"

find . -name 'sw.js' \
       -not -path './node_modules/*' \
       -not -path './.git/*' | while read SW; do
  if grep -q 'const CACHE_VERSION' "$SW"; then
    # Preserve the project prefix; replace only the v+timestamp portion.
    # Matches: CACHE_VERSION = 'prefix-v20260720221935'
    sed -i '' "s/\\(CACHE_VERSION = '[^']*-\\)v[0-9][0-9]*/\\1${VERSION}/" "$SW"
    git add "$SW"
    echo "  bumped: $SW -> ${VERSION}"
  fi
done
